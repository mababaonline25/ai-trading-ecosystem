@router.post("/watchlist")
async def add_to_watchlist(
    symbol: str,
    current_user = Depends(get_current_user)
):
    """ওয়াচলিস্টে যোগ করুন"""
    await market_repo.add_to_watchlist(current_user.id, symbol)
    return {"message": f"{symbol} added to watchlist"}


@router.delete("/watchlist/{symbol}")
async def remove_from_watchlist(
    symbol: str,
    current_user = Depends(get_current_user)
):
    """ওয়াচলিস্ট থেকে সরান"""
    await market_repo.remove_from_watchlist(current_user.id, symbol)
    return {"message": f"{symbol} removed from watchlist"}


@router.get("/watchlist")
async def get_watchlist(current_user = Depends(get_current_user)):
    """ওয়াচলিস্ট দেখুন"""
    watchlist = await market_repo.get_watchlist(current_user.id)
    return {"watchlist": watchlist}