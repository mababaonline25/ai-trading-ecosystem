"""
Market data endpoints
"""

from fastapi import APIRouter, Depends, HTTPException, Query
from typing import List, Optional
from datetime import datetime, timedelta

from ....core.market.exchange_manager import ExchangeManager
from ....core.market.data_collector import DataCollector
from ....core.market.real_time_analyzer import RealTimeAnalyzer
from ....core.analysis.technical.indicators import TechnicalIndicators
from ....core.analysis.technical.patterns import PatternDetector
from ....data.repositories.market_repo import MarketRepository
from ....utils.auth import get_current_user
from ....utils.rate_limiter import rate_limit
from ....utils.cache import cache_response

router = APIRouter()
exchange_manager = ExchangeManager()
data_collector = DataCollector()
real_time_analyzer = RealTimeAnalyzer()
market_repo = MarketRepository()


@router.get("/exchanges")
@rate_limit(requests=100, period=60)
async def get_exchanges():
    """সকল সমর্থিত এক্সচেঞ্জের তালিকা"""
    exchanges = exchange_manager.get_all_exchanges()
    return {
        "total": len(exchanges),
        "exchanges": exchanges
    }


@router.get("/symbols")
@rate_limit(requests=100, period=60)
@cache_response(ttl=300)
async def get_symbols(
    exchange: Optional[str] = None,
    quote_asset: Optional[str] = "USDT",
    min_volume: Optional[float] = None
):
    """সকল ট্রেডিং সিম্বলের তালিকা"""
    symbols = await exchange_manager.get_all_symbols(
        exchange=exchange,
        quote_asset=quote_asset,
        min_volume=min_volume
    )
    return {
        "total": len(symbols),
        "symbols": symbols
    }


@router.get("/price/{symbol}")
@rate_limit(requests=300, period=60)
@cache_response(ttl=10)
async def get_price(
    symbol: str,
    exchange: Optional[str] = "binance"
):
    """বর্তমান প্রাইস"""
    price = await exchange_manager.get_price(symbol, exchange)
    if price is None:
        raise HTTPException(status_code=404, detail="Symbol not found")
    
    return {
        "symbol": symbol,
        "exchange": exchange,
        "price": price,
        "timestamp": datetime.utcnow().isoformat()
    }


@router.get("/price/all/{symbol}")
@rate_limit(requests=100, period=60)
async def get_all_prices(symbol: str):
    """সকল এক্সচেঞ্জ থেকে প্রাইস"""
    prices = await exchange_manager.get_all_prices(symbol)
    return {
        "symbol": symbol,
        "prices": prices,
        "timestamp": datetime.utcnow().isoformat()
    }


@router.get("/klines/{symbol}")
@rate_limit(requests=200, period=60)
@cache_response(ttl=60)
async def get_klines(
    symbol: str,
    interval: str = Query("1h", regex="^(1m|5m|15m|30m|1h|4h|1d|1w)$"),
    limit: int = Query(100, ge=1, le=1000),
    exchange: Optional[str] = "binance"
):
    """ঐতিহাসিক ক্যান্ডেল ডেটা"""
    klines = await exchange_manager.get_klines(
        symbol=symbol,
        interval=interval,
        limit=limit,
        exchange=exchange
    )
    
    if not klines:
        raise HTTPException(status_code=404, detail="No data found")
    
    return {
        "symbol": symbol,
        "exchange": exchange,
        "interval": interval,
        "data": klines,
        "timestamp": datetime.utcnow().isoformat()
    }


@router.get("/ticker/{symbol}")
@rate_limit(requests=200, period=60)
async def get_ticker(
    symbol: str,
    exchange: Optional[str] = "binance"
):
    """সম্পূর্ণ টিকার তথ্য"""
    ticker = await exchange_manager.get_ticker(symbol, exchange)
    if not ticker:
        raise HTTPException(status_code=404, detail="Symbol not found")
    
    return ticker


@router.get("/orderbook/{symbol}")
@rate_limit(requests=200, period=60)
@cache_response(ttl=5)
async def get_orderbook(
    symbol: str,
    limit: int = Query(10, ge=1, le=100),
    exchange: Optional[str] = "binance"
):
    """অর্ডার বুক"""
    orderbook = await exchange_manager.get_orderbook(symbol, limit, exchange)
    if not orderbook:
        raise HTTPException(status_code=404, detail="Orderbook not found")
    
    return orderbook


@router.get("/trades/{symbol}")
@rate_limit(requests=200, period=60)
async def get_recent_trades(
    symbol: str,
    limit: int = Query(50, ge=1, le=1000),
    exchange: Optional[str] = "binance"
):
    """সাম্প্রতিক ট্রেড"""
    trades = await exchange_manager.get_recent_trades(symbol, limit, exchange)
    return {
        "symbol": symbol,
        "exchange": exchange,
        "trades": trades,
        "timestamp": datetime.utcnow().isoformat()
    }


@router.get("/stats/{symbol}")
@rate_limit(requests=100, period=60)
async def get_market_stats(
    symbol: str,
    exchange: Optional[str] = "binance"
):
    """মার্কেট স্ট্যাটিস্টিক্স"""
    stats = await exchange_manager.get_24h_stats(symbol, exchange)
    if not stats:
        raise HTTPException(status_code=404, detail="Stats not found")
    
    return stats


@router.get("/top-gainers")
@rate_limit(requests=50, period=60)
@cache_response(ttl=300)
async def get_top_gainers(
    limit: int = Query(10, ge=1, le=100),
    exchange: Optional[str] = "binance"
):
    """টপ গেইনার"""
    gainers = await data_collector.get_top_gainers(limit, exchange)
    return {
        "type": "gainers",
        "data": gainers,
        "timestamp": datetime.utcnow().isoformat()
    }


@router.get("/top-losers")
@rate_limit(requests=50, period=60)
@cache_response(ttl=300)
async def get_top_losers(
    limit: int = Query(10, ge=1, le=100),
    exchange: Optional[str] = "binance"
):
    """টপ লুজার"""
    losers = await data_collector.get_top_losers(limit, exchange)
    return {
        "type": "losers",
        "data": losers,
        "timestamp": datetime.utcnow().isoformat()
    }


@router.get("/top-volume")
@rate_limit(requests=50, period=60)
@cache_response(ttl=300)
async def get_top_volume(
    limit: int = Query(10, ge=1, le=100),
    exchange: Optional[str] = "binance"
):
    """টপ ভলিউম"""
    volume = await data_collector.get_top_volume(limit, exchange)
    return {
        "type": "volume",
        "data": volume,
        "timestamp": datetime.utcnow().isoformat()
    }


@router.get("/technical/{symbol}")
@rate_limit(requests=100, period=60)
async def get_technical_analysis(
    symbol: str,
    interval: str = "1h",
    exchange: Optional[str] = "binance"
):
    """টেকনিক্যাল অ্যানালাইসিস"""
    klines = await exchange_manager.get_klines(symbol, interval, 500, exchange)
    if not klines:
        raise HTTPException(status_code=404, detail="No data found")
    
    closes = [k['close'] for k in klines]
    highs = [k['high'] for k in klines]
    lows = [k['low'] for k in klines]
    volumes = [k['volume'] for k in klines]
    
    analysis = {
        "symbol": symbol,
        "interval": interval,
        "exchange": exchange,
        "timestamp": datetime.utcnow().isoformat(),
        "indicators": {
            "rsi": TechnicalIndicators.rsi(closes),
            "macd": TechnicalIndicators.macd(closes),
            "bollinger_bands": TechnicalIndicators.bollinger_bands(closes),
            "ema": {
                "ema9": TechnicalIndicators.ema(closes, 9),
                "ema20": TechnicalIndicators.ema(closes, 20),
                "ema50": TechnicalIndicators.ema(closes, 50),
                "ema200": TechnicalIndicators.ema(closes, 200)
            },
            "sma": {
                "sma20": TechnicalIndicators.sma(closes, 20),
                "sma50": TechnicalIndicators.sma(closes, 50),
                "sma200": TechnicalIndicators.sma(closes, 200)
            },
            "stochastic": TechnicalIndicators.stochastic(highs, lows, closes),
            "adx": TechnicalIndicators.adx(highs, lows, closes),
            "atr": TechnicalIndicators.atr(highs, lows, closes),
            "obv": TechnicalIndicators.obv(closes, volumes),
            "volume_profile": TechnicalIndicators.volume_profile(volumes),
            "support_resistance": TechnicalIndicators.support_resistance(highs, lows),
            "ichimoku": TechnicalIndicators.ichimoku(highs, lows, closes),
            "fibonacci": TechnicalIndicators.fibonacci(highs, lows),
            "pivot_points": TechnicalIndicators.pivot_points(highs, lows, closes)
        },
        "patterns": PatternDetector.detect_all(closes, highs, lows),
        "summary": real_time_analyzer.analyze(closes, volumes)
    }
    
    return analysis


