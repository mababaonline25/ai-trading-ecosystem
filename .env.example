# ==================== APPLICATION ====================
APP_NAME=AI Trading Ecosystem
APP_ENV=production
APP_VERSION=3.0.0
DEBUG=false
SECRET_KEY=your-super-secret-key-change-in-production
LOG_LEVEL=INFO

# ==================== DATABASES ====================
# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=trading_prod
DB_USER=trading_user
DB_PASSWORD=your-strong-db-password
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# MongoDB
MONGO_HOST=mongodb
MONGO_PORT=27017
MONGO_DB=trading_prod
MONGO_USER=trading_user
MONGO_PASSWORD=your-strong-mongo-password
MONGO_MAX_POOL_SIZE=100

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=your-strong-redis-password
REDIS_DB=0
REDIS_MAX_CONNECTIONS=50

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=trading_user
RABBITMQ_PASSWORD=your-strong-rabbitmq-password
RABBITMQ_VHOST=/

# ==================== JWT & AUTH ====================
JWT_SECRET=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ISSUER=trading-ecosystem

# ==================== SECURITY ====================
BCRYPT_ROUNDS=12
SESSION_TIMEOUT=3600
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900
PASSWORD_MIN_LENGTH=8
REQUIRE_2FA=false
CORS_ORIGINS=https://tradingecosystem.com,https://api.tradingecosystem.com

# ==================== EXCHANGE API KEYS ====================
# Binance
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key
BINANCE_TESTNET=true

# Coinbase
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_SECRET_KEY=your-coinbase-secret-key

# Kraken
KRAKEN_API_KEY=your-kraken-api-key
KRAKEN_SECRET_KEY=your-kraken-secret-key

# KuCoin
KUCOIN_API_KEY=your-kucoin-api-key
KUCOIN_SECRET_KEY=your-kucoin-secret-key
KUCOIN_PASSPHRASE=your-kucoin-passphrase

# Bybit
BYBIT_API_KEY=your-bybit-api-key
BYBIT_SECRET_KEY=your-bybit-secret-key

# OKX
OKX_API_KEY=your-okx-api-key
OKX_SECRET_KEY=your-okx-secret-key
OKX_PASSPHRASE=your-okx-passphrase

# ==================== AI & ML ====================
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GOOGLE_API_KEY=your-google-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key
AI_MODEL=gpt-4
AI_TEMPERATURE=0.7
ENABLE_AI_TRADING=true
MODEL_PATH=/app/models

# ==================== BLOCKCHAIN ====================
ETH_RPC_URL=https://mainnet.infura.io/v3/your-project-id
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ETHERSCAN_API_KEY=your-etherscan-api-key
BSCSCAN_API_KEY=your-bscscan-api-key

# ==================== SOCIAL MEDIA ====================
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
REDDIT_CLIENT_ID=your-reddit-client-id
REDDIT_CLIENT_SECRET=your-reddit-client-secret
DISCORD_BOT_TOKEN=your-discord-bot-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ==================== NOTIFICATIONS ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-email-password
EMAIL_FROM=noreply@tradingecosystem.com
SLACK_WEBHOOK_URL=your-slack-webhook-url
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# ==================== TRADING CONFIG ====================
DEFAULT_LEVERAGE=1
MAX_LEVERAGE=10
MIN_SIGNAL_CONFIDENCE=70
MAX_POSITION_SIZE=100000
DAILY_LOSS_LIMIT=5000
MAX_OPEN_POSITIONS=20
DEFAULT_RISK_PERCENT=2
ENABLE_PAPER_TRADING=true

# ==================== EXCHANGES ====================
ENABLED_EXCHANGES=binance,coinbase,kraken,kucoin,bybit,okx
DEFAULT_EXCHANGE=binance
WEBSOCKET_RECONNECT_DELAY=5

# ==================== FEATURE FLAGS ====================
ENABLE_AI_TRADING=true
ENABLE_SOCIAL_TRADING=true
ENABLE_COPY_TRADING=true
ENABLE_BACKTESTING=true
ENABLE_PAPER_TRADING=true
ENABLE_MARGIN_TRADING=false
ENABLE_FUTURES_TRADING=false
ENABLE_OPTIONS_TRADING=false

# ==================== MONITORING ====================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
ALERTMANAGER_PORT=9093
METRICS_ENABLED=true
TRACING_ENABLED=true
SENTRY_DSN=your-sentry-dsn
NEW_RELIC_LICENSE_KEY=your-new-relic-key

# ==================== LOGGING ====================
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200
KIBANA_HOST=kibana
KIBANA_PORT=5601
LOGSTASH_HOST=logstash
LOGSTASH_PORT=5000
LOG_RETENTION_DAYS=30

# ==================== BACKUP ====================
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=trading-backups-prod
BACKUP_S3_REGION=us-east-1

# ==================== CLOUD PROVIDERS ====================
# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=trading-assets

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCP_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com

# Azure
AZURE_SUBSCRIPTION_ID=your-azure-subscription-id
AZURE_TENANT_ID=your-azure-tenant-id
AZURE_CLIENT_ID=your-azure-client-id
AZURE_CLIENT_SECRET=your-azure-client-secret

# ==================== SSL/TLS ====================
SSL_CERT_PATH=/etc/ssl/certs/trading.crt
SSL_KEY_PATH=/etc/ssl/private/trading.key
SSL_CA_PATH=/etc/ssl/certs/ca.crt

# ==================== DOMAINS ====================
DOMAIN_NAME=tradingecosystem.com
API_DOMAIN=api.tradingecosystem.com
WS_DOMAIN=ws.tradingecosystem.com
GRAFANA_DOMAIN=grafana.tradingecosystem.com
KIBANA_DOMAIN=kibana.tradingecosystem.com

# ==================== RATE LIMITING ====================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60
API_TIMEOUT=30

# ==================== CACHE ====================
CACHE_TTL=300
MARKET_DATA_TTL=10
PRICE_CACHE_TTL=5

# ==================== PERFORMANCE ====================
WORKER_CONCURRENCY=4
MAX_REQUESTS=1000
KEEPALIVE=5
GRACEFUL_TIMEOUT=120

# ==================== TESTING ====================
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=trading_test
TEST_REDIS_HOST=localhost
TEST_REDIS_PORT=6379
TEST_MONGO_HOST=localhost
TEST_MONGO_PORT=27017